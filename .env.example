# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# GitHub App (create at github.com/settings/apps)
GITHUB_APP_ID=123456
GITHUB_WEBHOOK_SECRET=your-random-secret

# Paste the contents of your .pem private key on one line with \n for newlines
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"

# Database (default is local SQLite — fine for dev and small deployments)
DATABASE_URL=sqlite+aiosqlite:///./reviews.db

# Frontend URL for CORS (set to your deployed frontend URL in production)
FRONTEND_URL=http://localhost:5173
